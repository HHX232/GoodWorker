generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model RateLimit {
  id      String   @id @default(cuid())
  key     String   @unique
  count   Int      @default(1)
  resetAt DateTime

  @@index([key])
}

model Student {
  id                     String                   @id @default(uuid())
  name                   String
  nameTransliterated     String?
  email                  String                   @unique
  phone                  String?
  langCode               String                   @default("ru")
  telegramChatId         BigInt?
  telegramLinkToken      String?                  @unique
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  avatarUrl              String?
  password               String?
  isVip                  Boolean                  @default(false)
  vipExpiresAt           DateTime?
  complaints             Complaint[]
  errors                 StudentError[]
  favoritePosts          StudentFavoritePost[]
  roadmapProgress        StudentRoadmapProgress[]
  savedTexts             StudentSavedText[]
  testAttempts           StudentTestAttempt[]
  teachers               TeacherStudent[]
  postViews              PostView[]
  conferenceParticipants ConferenceParticipant[]
  postAllowedStudents    PostAllowedStudent[]
  lastSeenAt             DateTime?
  isBanned               Boolean   @default(false)
  bannedAt               DateTime?
  banReason              String?
  transactions           VipTransaction[]
  roadmapAccess          RoadmapAccess[]
  nodeFeedbacks          RoadmapNodeFeedback[]
  roadmapViews           RoadmapView[]
  notifications          Notification[]
  serviceBookings        ServiceBooking[]
  personalServices       Service[]        @relation("PersonalServices")
  supportRequests        SupportRequest[]
  feedbackPromoGiven     Boolean          @default(false)
}

model Teacher {
  id                 String            @id @default(uuid())
  name               String
  nameTransliterated String?
  email              String            @unique
  avatarUrl          String?
  langCode           String            @default("ru")
  telegramChatId     BigInt?
  telegramLinkToken  String?           @unique
  calendar           Json?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  password           String?
  pasportConfirmed   Boolean?
  phone              String?
  isVip              Boolean           @default(false)
  vipExpiresAt       DateTime?
  bio                String?
  coverPhotoUrl      String?
  socialLinks        Json?
  languages          String[]          @default(["ru"])
  transactions       VipTransaction[]
  complaints         Complaint[]
  posts              Post[]
  roadmaps           Roadmap[]
  categories         TeacherCategory[]
  students           TeacherStudent[]
  tests              Test[]
  conferences        Conference[]
  lastSeenAt         DateTime?
  isBanned           Boolean   @default(false)
  bannedAt           DateTime?
  banReason          String?
  roadmapViews       RoadmapView[]
  notifications      Notification[]
  reviews            TeacherReview[]
  services           Service[]
  passportDocumentUrl String?
  experiences         TeacherExperience[]
  supportRequests     SupportRequest[]
  feedbackPromoGiven  Boolean             @default(false)
}

model TeacherExperience {
  id              String    @id @default(uuid())
  teacherId       String
  title           String
  organization    String?
  yearFrom        Int
  yearTo          Int?
  description     String?
  documentUrls    String[]  @default([])
  verifiedAt      DateTime?
  verifiedByAdmin String?
  createdAt       DateTime  @default(now())
  teacher         Teacher   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
}

model TeacherReview {
  id         String   @id @default(uuid())
  teacherId  String
  authorId   String
  authorRole String   @default("STUDENT")
  authorName String
  text       String
  stars      Int
  createdAt  DateTime @default(now())
  teacher    Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, authorId])
}

model Service {
  id                     String             @id @default(uuid())
  teacherId              String
  title                  String
  description            String?
  photoUrl               String?
  categoryId             String?
  duration               Int
  timeFrom               String
  timeTo                 String
  isGroup                Boolean            @default(false)
  price                  Float
  createdAt              DateTime           @default(now())
  targetStudentId        String?
  isPersonal             Boolean            @default(false)
  titleTranslations      Json?
  descriptionTranslations Json?
  teacher         Teacher            @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  category        Category?          @relation(fields: [categoryId], references: [id])
  promoCodes      ServicePromoCode[]
  bookings        ServiceBooking[]
  conferences     Conference[]
  targetStudent   Student?           @relation("PersonalServices", fields: [targetStudentId], references: [id], onDelete: SetNull)
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model ServiceBooking {
  id          String        @id @default(uuid())
  serviceId   String
  studentId   String
  status      BookingStatus @default(PENDING)
  promoCode   String?
  finalPrice  Float
  createdAt   DateTime      @default(now())
  service     Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  student     Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([serviceId, studentId])
  @@index([studentId])
}

model ServicePromoCode {
  id         String   @id @default(uuid())
  serviceId  String
  code       String
  discount   Int
  usageLimit Int?
  usedCount  Int      @default(0)
  conditions String?
  createdAt  DateTime @default(now())
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, code])
}

model TeacherStudent {
  teacherId String
  studentId String
  linkedAt  DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@id([teacherId, studentId])
}

model Category {
  id                     String                 @id @default(uuid())
  slug                   String                 @unique
  levelNumber            Int
  parentId               String?
  parent                 Category?              @relation("CategoryChildren", fields: [parentId], references: [id])
  children               Category[]             @relation("CategoryChildren")
  translations           CategoryTranslation[]
  posts                  Post[]
  studentErrorCategories StudentErrorCategory[]
  teachers               TeacherCategory[]
  testCategories         TestCategory[]
  conferenceCategories   ConferenceCategory[]
  services               Service[]
}

model CategoryTranslation {
  id         String   @id @default(uuid())
  categoryId String
  langCode   String
  name       String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, langCode])
}

model TeacherCategory {
  teacherId  String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  teacher    Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@id([teacherId, categoryId])
}

model Post {
  id             String                @id @default(uuid())
  teacherId      String
  categoryId     String?
  title          String
  content        Json?
  mediaUrls      String[]
  visibility     PostVisibility        @default(PUBLIC)
  viewCount      Int                   @default(0)
  aiTopics       String[]
  aiModerated    Boolean               @default(false)
  aiModerationOk Boolean?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  complaints     Complaint[]
  category       Category?             @relation(fields: [categoryId], references: [id])
  teacher        Teacher               @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  comments       PostComment[]
  ratings        PostRating[]
  favoritedBy    StudentFavoritePost[]
  views          PostView[]

  additionalTitle String?
  isVip           Boolean   @default(false)
  vipExpiresAt    DateTime?
  moderationStatus ModerationStatus @default(PUBLISHED)

  titleTranslations           Json?
  additionalTitleTranslations Json?
  contentTranslations         Json?

  allowedStudents  PostAllowedStudent[]
  miniTestAttempts PostTestAttempt[]
}

model PostTestAttempt {
  id         String   @id @default(uuid())
  postId     String
  testId     String
  studentId  String?
  teacherId  String?
  score      Float?
  maxScore   Float?
  percent    Float?
  createdAt  DateTime @default(now())
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Bookmark {
  id          String   @id @default(uuid())
  authorId    String
  authorRole  Role
  sourceType  String // "post" | "text" | "roadmap"
  sourceId    String
  text        String
  xpath       String  @default("")
  contextText String   @default("") // весь параграф
  offset      Int      @default(0)
  length      Int
  createdAt   DateTime @default(now())

  @@index([authorId])
  @@index([sourceType, sourceId])
}

model PostAllowedStudent {
  postId    String
  studentId String
  post      Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([postId, studentId])
  @@index([postId])
}

model PostView {
  id         String   @id @default(uuid())
  postId     String
  viewerRole Role
  studentId  String?
  teacherId  String?
  viewedAt   DateTime @default(now())
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  student    Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  @@unique([postId, studentId])
  @@index([postId])
  @@index([studentId])
}

model PostComment {
  id               String    @id @default(uuid())
  postId           String
  authorId         String
  authorRole       Role
  text             String
  imageUrls        String[]  @default([])
  editedAt         DateTime?
  createdAt        DateTime  @default(now())
  textTranslations Json?
  post             Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model PostRating {
  id         String   @id @default(uuid())
  postId     String
  authorId   String
  authorRole Role
  stars      Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, authorId])
  @@index([postId])
}

model StudentFavoritePost {
  studentId String
  postId    String
  savedAt   DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([studentId, postId])
}

model Roadmap {
  id                  String                    @id @default(uuid())
  teacherId           String
  title               String
  price               Float                     @default(0)
  content             Json
  previewImageUrl     String?
  treeSnapshotUrl     String?
  nodeAccessType      RoadmapNodeAccessType?
  titleTranslations   Json?
  contentTranslations Json?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  moderationStatus    ModerationStatus          @default(PUBLISHED)
  complaints      Complaint[]
  teacher         Teacher                   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  progress        StudentRoadmapProgress[]
  comments        RoadmapComment[]
  ratings         RoadmapRating[]
  accessList      RoadmapAccess[]
  nodeFeedbacks   RoadmapNodeFeedback[]
  views           RoadmapView[]
}

model RoadmapView {
  id         String   @id @default(uuid())
  roadmapId  String
  viewerRole Role
  studentId  String?
  teacherId  String?
  viewedAt   DateTime @default(now())
  roadmap    Roadmap  @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  student    Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)
  teacher    Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)

  @@unique([roadmapId, studentId])
  @@index([roadmapId])
}

model RoadmapAccess {
  roadmapId String
  studentId String
  grantedBy RoadmapAccessGrant @default(TEACHER)
  createdAt DateTime           @default(now())
  roadmap   Roadmap            @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  student   Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([roadmapId, studentId])
  @@index([roadmapId])
  @@index([studentId])
}

model RoadmapNodeFeedback {
  id        String   @id @default(uuid())
  roadmapId String
  nodeId    String
  studentId String
  answers   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  roadmap   Roadmap  @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([roadmapId, nodeId, studentId])
  @@index([roadmapId])
  @@index([studentId])
}

model RoadmapComment {
  id         String    @id @default(uuid())
  roadmapId  String
  authorId   String
  authorRole Role
  text       String
  imageUrls  String[]  @default([])
  editedAt   DateTime?
  createdAt  DateTime  @default(now())
  roadmap    Roadmap   @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@unique([roadmapId, authorId])
  @@index([roadmapId])
  @@index([authorId])
}

model RoadmapRating {
  id        String   @id @default(uuid())
  roadmapId String
  authorId  String
  authorRole Role
  stars     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  roadmap   Roadmap  @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@unique([roadmapId, authorId])
  @@index([roadmapId])
}

model StudentRoadmapProgress {
  id             String    @id @default(uuid())
  studentId      String
  roadmapId      String
  completedSteps String[]
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  roadmap        Roadmap   @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  student        Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, roadmapId])
}

model Test {
  id             String               @id @default(uuid())
  teacherId      String
  title          String
  aiTopic        String?
  content        Json
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  attempts       StudentTestAttempt[]
  teacher        Teacher              @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  testCategories TestCategory[]
}

model TestCategory {
  testId     String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  test       Test     @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@id([testId, categoryId])
}

model StudentTestAttempt {
  id            String         @id @default(uuid())
  studentId     String
  testId        String
  score         Float?
  maxScore      Float?
  percent       Float?
  answers       Json
  blockResults  Json?
  startedAt     DateTime       @default(now())
  finishedAt    DateTime?
  student       Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  test          Test           @relation(fields: [testId], references: [id], onDelete: Cascade)
  studentErrors StudentError[]
}

model StudentSavedText {
  id            String   @id @default(uuid())
  studentId     String
  title         String?
  rawText       String
  correctedText String?
  errors        Json?
  createdAt     DateTime @default(now())
  postId        String?
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model StudentError {
  id          String                 @id @default(uuid())
  studentId   String
  sourceType  String
  sourceId    String
  attemptId   String?
  description  String?
  fragment     String?
  isCorrection Boolean                @default(false)
  createdAt    DateTime               @default(now())
  attempt      StudentTestAttempt?    @relation(fields: [attemptId], references: [id], onDelete: SetNull)
  student     Student                @relation(fields: [studentId], references: [id], onDelete: Cascade)
  categories  StudentErrorCategory[]
}

model StudentErrorCategory {
  errorId    String
  categoryId String
  category   Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  error      StudentError @relation(fields: [errorId], references: [id], onDelete: Cascade)

  @@id([errorId, categoryId])
}

model Complaint {
  id           String   @id @default(uuid())
  reporterId   String
  reporterRole Role
  targetType   String
  targetId     String
  text         String
  photoUrl     String?
  status       String   @default("pending")
  reply        String?
  repliedAt    DateTime?
  createdAt    DateTime @default(now())
  teacherId    String?
  studentId    String?
  postId       String?
  roadmapId    String?
  post         Post?    @relation(fields: [postId], references: [id])
  roadmap      Roadmap? @relation(fields: [roadmapId], references: [id])
  student      Student? @relation(fields: [studentId], references: [id])
  teacher      Teacher? @relation(fields: [teacherId], references: [id])
}

model OtpCode {
  id        String   @id @default(cuid())
  target    String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([target])
}

model Conference {
  id          String  @id @default(uuid())
  teacherId   String
  title       String
  description String?

  scheduledAt DateTime?
  startedAt   DateTime?
  endedAt     DateTime?

  status ConferenceStatus @default(SCHEDULED)

  roomName     String  @unique
  recordingUrl String?

  transcriptRaw    String?
  transcriptJson   Json?
  transcriptStatus TranscriptStatus @default(NONE)

  mediaNodes      Json?
  durationMinutes Int?
  serviceId       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacher      Teacher                 @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  service      Service?                @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  participants ConferenceParticipant[]
  categories   ConferenceCategory[]
}

model ConferenceCategory {
  conferenceId String
  categoryId   String
  category     Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  conference   Conference @relation(fields: [conferenceId], references: [id], onDelete: Cascade)

  @@id([conferenceId, categoryId])
}

model ConferenceParticipant {
  id           String     @id @default(uuid())
  conferenceId String
  studentId    String?
  teacherId    String?
  role         Role
  joinedAt     DateTime?
  leftAt       DateTime?
  conference   Conference @relation(fields: [conferenceId], references: [id], onDelete: Cascade)
  student      Student?   @relation(fields: [studentId], references: [id], onDelete: SetNull)

  @@index([conferenceId])
  @@index([studentId])
}

model PromoCode {
  id              String          @id @default(uuid())
  code            String          @unique
  rewardType      PromoRewardType
  discountPercent Int?
  vipDays         Int             @default(30)
  description     String
  maxUses         Int?
  usedCount       Int             @default(0)
  expiresAt       DateTime?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  transactions    VipTransaction[]
}

model VipTransaction {
  id              String          @id @default(uuid())
  teacherId       String?
  studentId       String?
  userRole        Role
  type            TransactionType
  amount          Float           @default(0)
  description     String
  promoCodeId     String?
  vipGrantedUntil DateTime?
  createdAt       DateTime        @default(now())
  teacher         Teacher?        @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  student         Student?        @relation(fields: [studentId], references: [id], onDelete: SetNull)
  promoCode       PromoCode?      @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)

  @@index([teacherId])
  @@index([studentId])
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum PromoRewardType {
  FREE_VIP
  DISCOUNT
}

enum TransactionType {
  VIP_PURCHASE
  VIP_PROMO
  DEPOSIT
}

enum PostVisibility {
  PUBLIC
  STUDENTS
  SELECTED
  PRIVATE
}

enum ModerationStatus {
  PUBLISHED
  PENDING
  BLOCKED
}

enum ConferenceStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

enum TranscriptStatus {
  NONE
  PROCESSING
  DONE
  FAILED
}

enum RoadmapAccessGrant {
  TEACHER
  PURCHASE
}

enum RoadmapNodeAccessType {
  STUDENTS
  SELECTED
  PURCHASE
}

enum RoomAccessType {
  ALL
  NOBODY
  MY_STUDENTS
  SELECTED
}

// ─── Notifications ────────────────────────────────────────

model Notification {
  id                 String   @id @default(uuid())
  type               String
  title              String
  body               String
  titleTranslations  Json?
  bodyTranslations   Json?
  payload            Json?
  isRead             Boolean  @default(false)
  createdAt          DateTime @default(now())
  teacherId          String?
  studentId          String?
  teacher            Teacher? @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  student            Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([teacherId, isRead])
  @@index([studentId, isRead])
  @@index([createdAt])
}

model VideoCallRoom {
  id            String         @id @default(cuid())
  name          String         @unique
  ownerIdentity String
  ownerId       String
  ownerRole     Role
  createdAt     DateTime       @default(now())
  endedAt       DateTime?

  topic         String?
  categoryId    String?
  accessType    RoomAccessType @default(ALL)
  allowedEmails String[]

  transcriptRaw  String?
  transcriptJson Json?

  participants   VideoCallParticipant[]
}

model VideoCallParticipant {
  id       String   @id @default(cuid())
  roomId   String
  identity String
  userId   String?
  userRole Role?
  joinedAt DateTime @default(now())

  room VideoCallRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([userId])
}

model NotificationSubscription {
  id       String  @id @default(uuid())
  userId   String
  userRole String
  type     String
  enabled  Boolean @default(true)

  @@unique([userId, type])
  @@index([userId])
}

model AdminEmail {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model SupportRequest {
  id         String   @id @default(uuid())
  authorId   String
  authorRole Role
  title      String
  text       String
  photoUrls  String[] @default([])
  status     String   @default("pending")
  reply      String?
  createdAt  DateTime @default(now())

  student Student? @relation(fields: [authorId], references: [id], onDelete: Cascade, map: "support_student_fk")
  teacher Teacher? @relation(fields: [authorId], references: [id], onDelete: Cascade, map: "support_teacher_fk")

  @@index([authorId])
}
