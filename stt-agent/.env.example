# LiveKit (одинаково для локали и Railway)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# Whisper настройки
WHISPER_MODEL=base        # tiny | base | small
WHISPER_LANGUAGE=ru       # ru, en, или оставь пустым для авто-определения
CHUNK_SECONDS=3           # как часто транскрибировать (в секундах)
