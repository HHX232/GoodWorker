# Создать новый .npmrc с настройками для Windows
@"
# Включить опциональные зависимости
optional=true

# Явно указать платформу
platform=win32
arch=x64

# Отключить проверку движка
engine-strict=false

# Использовать legacy peer deps
legacy-peer-deps=true
"@ | Out-File -FilePath .npmrc -Encoding utf8